Algoritmo producto_y_cociente
	
	Definir num1, num2, producto, cociente Como Real
	
	Escribir "Por favor escriba el primer número:"
	Leer num1
	
	Escribir "Ahora escriba el segundo número:"
	Leer num2
	
	producto <- num1 * num2
	cociente <- num1 / num2
	
	Escribir "La multiplicación de los números es: ", producto
	Escribir "La división de los números es: ", cociente
	
FinAlgoritmo
