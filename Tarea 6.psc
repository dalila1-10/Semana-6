Algoritmo sumar_y_restar_numeros
	
	Definir numero1, numero2, suma, resta Como Real
	
	Escribir "Por favor ingrese el primer número:"
	Leer numero1
	
	Escribir "Ahora ingrese el segundo número:"
	Leer numero2
	
	suma <- numero1 + numero2
	resta <- numero1 - numero2
	
	Escribir "La suma de los números es: ", suma
	Escribir "La resta de los números es: ", resta
	
FinAlgoritmo
