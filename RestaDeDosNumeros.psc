Algoritmo RestaDeDosNumeros
	
	Definir num1, num2, resultado Como Real
	
	Escribir "Vamos a realizar una resta."
	
	Escribir "Ingrese el primer número:"
	Leer num1
	
	Escribir "Ingrese el segundo número:"
	Leer num2
	
	resultado <- num1 - num2
	
	Escribir "El resultado de restar ", num2, " a ", num1, " es: ", resultado
	
FinAlgoritmo
