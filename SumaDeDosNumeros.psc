Algoritmo SumaDeDosNumeros
	
	Definir num1, num2, suma Como Entero
	
	Escribir "Vamos a sumar dos números."
	
	Escribir "Por favor ingrese el primer número:"
	Leer num1
	
	Escribir "Ahora ingrese el segundo número:"
	Leer num2
	
	suma <- num1 + num2
	
	Escribir "La suma de ", num1, " y ", num2, " es: ", suma
	
FinAlgoritmo
