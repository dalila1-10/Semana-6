Algoritmo MultiplicacionDeDosNumeros
	
	Definir num1, num2, resultado Como Real
	
	Escribir "Vamos a multiplicar dos nºmeros."
	
	Escribir "Por favor ingresa el primer nºmero:"
	Leer num1
	
	Escribir "Por favor ingresa el segundo nºmero:"
	Leer num2
	
	resultado <- num1 * num2
	
	Escribir "El resultado de la multiplicaciµn es: ", resultado
	
FinAlgoritmo
