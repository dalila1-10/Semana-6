Algoritmo PromedioDeTresNumeros
	
	Definir num1, num2, num3, promedio Como Real
	
	Escribir "Vamos a calcular el promedio de tres números."
	
	Escribir "Por favor ingresa el primer número:"
	Leer num1
	
	Escribir "Ingrese el segundo número:"
	Leer num2
	
	Escribir "Ahora ingresa el tercer número:"
	Leer num3
	
	promedio <- (num1 + num2 + num3) / 3
	
	Escribir "El promedio de los números es: ", promedio
	
FinAlgoritmo
