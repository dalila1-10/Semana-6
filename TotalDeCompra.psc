Algoritmo TotalDeCompra
	
	Definir precio, cantidad, total Como Real
	
	Escribir "Por favor calcular el total de su compra."
	
	Escribir "Ingresa el precio del producto:"
	Leer precio
	
	Escribir "Ingresa la cantidad que desea comprar:"
	Leer cantidad
	
	total <- precio * cantidad
	
	Escribir "El total que debe pagar es: ", total
	
FinAlgoritmo
