Algoritmo NumeroPositivoMenorQue100
	
	Definir numero Como Entero
	
	Escribir "Hola, por favor escribe un número para revisarlo:"
	Leer numero
	
	Si numero > 0 Y numero < 100 Entonces
		Escribir "El número que escribiste es positivo y menor que 100."
		Escribir "Resultado: Verdadero"
	SiNo
		Escribir "El número que escribiste no cumple con la condición."
		Escribir "Resultado: Falso"
	FinSi
	
FinAlgoritmo
