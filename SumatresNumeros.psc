Algoritmo SumaDeTresNumeros
	
	Definir num1, num2, num3, suma Como Real
	
	Escribir "Vamos a sumar tres números."
	
	Escribir "Por favor ingresa el primer número:"
	Leer num1
	
	Escribir "Ingresa el segundo número:"
	Leer num2
	
	Escribir "Ahora ingresa el tercer número:"
	Leer num3
	
	suma <- num1 + num2 + num3
	
	Escribir "La suma total de los tres números es: ", suma
	
FinAlgoritmo
