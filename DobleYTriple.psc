Algoritmo DobleYTriple
	
	Definir numero, doble, triple Como Real
	
	Escribir "Por favor ingresa un número y muestrame su doble y su triple:"
	Leer numero
	
	doble <- numero * 2
	triple <- numero * 3
	
	Escribir "El doble del número es: ", doble
	Escribir "El triple del número es: ", triple
	
FinAlgoritmo
